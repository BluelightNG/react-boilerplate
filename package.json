{
  "name": "react-boilerplate",
  "private": true,
  "version": "0.2.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "release": "dotenv release-it --",
    "release:patch": "dotenv release-it -- --increment patch",
    "release:minor": "dotenv release-it -- --increment minor",
    "release:major": "dotenv release-it -- --increment major",
    "clear": "rm -rf node_modules && rm -rf package-lock.j",
    "kill": "npx kill-port 3001",
    "lint:fix": "yarn run lint -- --fix",
    "format": "prettier --write \"{,!(node_modules)/**/}*.js\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@reduxjs/toolkit": "^2.2.7",
    "@types/react-router-dom": "^5.3.3",
    "@types/styled-components": "^5.1.34",
    "axios": "^1.7.5",
    "axios-auth-refresh": "^3.3.6",
    "axios-retry": "^4.5.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.53.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.26.1",
    "react-secure-storage": "^1.3.2",
    "redux-persist": "^6.0.0",
    "sonner": "^1.7.0",
    "styled-components": "^6.1.12",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@release-it/conventional-changelog": "^9.0.3",
    "@types/bun": "latest",
    "@types/node": "^22.5.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.6",
    "husky": "^9.1.6",
    "path": "^0.12.7",
    "prettier": "^3.3.3",
    "release-it": "^17.10.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "module": "index.ts",
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "infile": "CHANGELOG.md",
        "preset": {
          "name": "conventionalcommits",
          "type": [
            {
              "type": "feat",
              "section": "Features"
            },
            {
              "type": "fix",
              "section": "Bug Fixes"
            }
          ]
        }
      }
    }
  }
}
